<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>FortunateWins Login</title>

    <style>
        :root{
            --accent-orange: #FF8C42;
            --headings: rgb(56, 58, 58);
            --white: #ffffff;
            --light: #f5f5f5;
        }

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            min-height:100vh;
            display:flex;
            justify-content:center;
            align-items:center;
            background:linear-gradient(
                135deg,
                var(--headings),
                #222
            );
            padding:20px;
        }

        .login-container{
            width:100%;
            max-width:420px;
            background:rgba(255,255,255,0.95);
            border-radius:20px;
            padding:40px;
            box-shadow:0 15px 35px rgba(0,0,0,.25);
        }

        .logo{
            text-align:center;
            margin-bottom:10px;
            font-size:2rem;
            font-weight:bold;
            color:var(--headings);
        }

        .logo span{
            color:var(--accent-orange);
        }

        .subtitle{
            text-align:center;
            color:#777;
            margin-bottom:30px;
        }

        .input-group{
            margin-bottom:20px;
        }

        .input-group label{
            display:block;
            margin-bottom:8px;
            color:var(--headings);
            font-weight:600;
        }

        .input-group input{
            width:100%;
            padding:14px;
            border:2px solid #ddd;
            border-radius:10px;
            font-size:1rem;
            transition:.3s;
        }

        .input-group input:focus{
            outline:none;
            border-color:var(--accent-orange);
            box-shadow:0 0 10px rgba(255,140,66,.25);
        }

        .login-btn{
            width:100%;
            padding:14px;
            border:none;
            border-radius:10px;
            background:linear-gradient(
                to right,
                var(--accent-orange),
                #ff9f5a
            );
            color:white;
            font-size:1rem;
            font-weight:bold;
            cursor:pointer;
            transition:.3s;
        }

        .login-btn:hover{
            transform:translateY(-2px);
        }

        .links{
            text-align:center;
            margin-top:20px;
        }

        .links a{
            color:var(--accent-orange);
            text-decoration:none;
            font-weight:600;
        }

        .links a:hover{
            text-decoration:underline;
        }

        .message{
            text-align:center;
            margin-bottom:15px;
            color:red;
        }
    </style>
</head>
<body>

    <div class="login-container">

        <div class="logo">
            Fortunate<span>Wins</span>
        </div>

        <p class="subtitle">Sign in to your account</p>

        <% if(typeof message !== 'undefined'){ %>
            <p class="message"><%= message %></p>
        <% } %>

        <form action="/login" method="POST">

            <div class="input-group">
                <label>Email</label>
                <input
                    type="email"
                    name="Email"
                    placeholder="Enter your email"
                    required
                >
            </div>

            <div class="input-group">
                <label>Password</label>
                <input
                    type="password"
                    name="Password"
                    placeholder="Enter your password"
                    required
                >
            </div>

            <button type="submit" class="login-btn">
                Login
            </button>

        </form>

       
    </div>

</body>
</html>